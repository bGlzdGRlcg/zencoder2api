# Server Configuration
PORT=8080
BIND_ADDRESS=127.0.0.1
MAX_REQUEST_BODY_BYTES=4194304
MAX_CONCURRENT_REQUESTS=32
REQUESTS_PER_MINUTE=600
ADMIN_LOGIN_REQUESTS_PER_MINUTE=10

# Comma-separated IP/CIDR list for the only reverse proxies allowed to supply
# forwarded client addresses. Leave empty when connecting directly.
TRUSTED_PROXIES=

# Set true only for unauthenticated local development. The server will refuse
# this mode unless BIND_ADDRESS is loopback.
ALLOW_INSECURE_LOCALHOST=false

# Database Configuration
DB_PATH=data.db
CREDIT_RESET_TIMEZONE=UTC
CREDIT_RESET_AT=09:09
# Refresh real usage-based account balances. Supported range: 1m to 24h.
USAGE_CREDITS_REFRESH_INTERVAL=15m

# Authentication
# Required. Generate a unique random value with at least 16 characters.
AUTH_TOKEN=

# Required and must differ from AUTH_TOKEN.
ADMIN_PASSWORD=

# Required. Base64-encoded 32-byte key used to encrypt OAuth/API-key credentials at rest.
# Example generator: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Required when the service is published behind a reverse proxy.
PUBLIC_BASE_URL=
# Set true when the reverse proxy terminates HTTPS. The cookie is always
# HttpOnly and SameSite=Strict; this flag only controls the Secure attribute.
ADMIN_COOKIE_SECURE=false

# Compose deployment only: use an immutable image reference, never a tag.
# Compose adds "@" between these values, so a mutable tag is not accepted.
ZENCODER2API_IMAGE_REPOSITORY=ghcr.io/bglzdgrlcg/zencoder2api
ZENCODER2API_IMAGE_DIGEST=
CPU_LIMIT=1.0
MEMORY_LIMIT=512m
PIDS_LIMIT=128
TZ=UTC

# Logging
LOG_LEVEL=silent
DEBUG=false
